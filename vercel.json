{
  "builds": [
    {
      "src": "app/asgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/vercel/output/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/vercel/output/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app/asgi.py"
    }
  ],
  "buildCommand": "python3 manage.py collectstatic --noinput"
}